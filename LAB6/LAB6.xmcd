		<region region-id="499" left="12" top="1890" width="459" height="60" align-x="39.75" align-y="1902" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Comment" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Висновок: На цьому занятті я ознайомився з методами обчислення визначених інтегралів і набув практичних навичок їх розрахунку за допомогою пакета Mathcad. Я навчився застосовувати відповідні інструменти для точного та ефективного обчислення визначених інтегралів.</p>
			</text>
		</region>
	</regions>
