		<region region-id="300" left="24" top="3216" width="345" height="189.75" align-x="24" align-y="3216" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<plot disable-calc="false" item-idref="67"/>
