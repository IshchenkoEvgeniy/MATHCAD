			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Comment" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Побудуємо в одній площині результати розв’язання диференціального рівняння всіма методами</p>
			</text>
		</region>
		<region region-id="1480" left="12" top="4698" width="468.75" height="237" align-x="12" align-y="4698" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<plot disable-calc="false" item-idref="106"/>
			<rendering item-idref="107"/>
		</region>
		<region region-id="1496" left="12" top="4962" width="402.75" height="90" align-x="39.75" align-y="4974" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Comment" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Висновок: На цьому занятті я освоїв методи розв’язування диференціальних рівнянь та їх систем за допомогою пакета Mathcad. Я набув практичних навичок у розв’язуванні як окремих диференціальних рівнянь, так і їх систем, використовуючи інструменти Mathcad для ефективного обчислення та аналізу результатів.</p>
			</text>
		</region>
	</regions>
